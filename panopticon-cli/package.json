{
  "name": "@inkbinder/panopticon-cli",
  "version": "0.1.0",
  "description": "CLI interface for panopticon",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@inkbinder/panopticon-daemon": "*",
    "commander": "^13.0.0",
    "cross-spawn": "^7.0.6",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.2",
    "supertest": "^7.1.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.2"
  },
  "bin": {
    "panopticon-cli": "dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Inkbinder/panopticon.git",
    "directory": "packages/panopticon-cli"
  },
  "homepage": "https://github.com/Inkbinder/panopticon#readme",
  "bugs": {
    "url": "https://github.com/Inkbinder/panopticon/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
